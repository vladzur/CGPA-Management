{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@cgpa/shared$": "<rootDir>/../../../packages/shared/src/index.ts",
    "^uuid$": "<rootDir>/uuid-mock.js"
  }
}
